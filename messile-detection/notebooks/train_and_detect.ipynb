#cell2

import os
import yaml

dataset_path = "/content/Missiles-1"
yaml_file = os.path.join(dataset_path, "data.yaml")

if not os.path.exists(yaml_file):
    print("⚠️ data.yaml not found! Check the folder structure.")
else:
    with open(yaml_file, 'r') as f:
        data = yaml.safe_load(f)

    print("✅ data.yaml found. Contents:\n")
    print(f"Number of classes (nc): {data.get('nc', 'Not specified')}")
    print(f"Class names: {data.get('names', 'Not specified')}")
    print(f"Train folder: {data.get('train')}")
    print(f"Validation folder: {data.get('val')}")
    # Check if it's a segmentation dataset
    if 'masks' in data:
        print("🎯 This is a SEGMENTATION dataset (masks present).")
    else:
        print("📦 This is a DETECTION dataset (bounding boxes only).")

#cell3

!pip install ultralytics -q
from ultralytics import YOLO

data_yaml = "/content/Missiles-1/data.yaml"

# Load a pretrained YOLOv8 nano model (fast, good starting point)
model = YOLO("yolov8n.pt")

# Train
results = model.train(
    data=data_yaml,
    epochs=50,           # change to 100 if dataset is large
    imgsz=640,
    batch=16,            # reduce to 8 if you get CUDA out-of-memory
    name="missile_det",
    patience=10,         # stop early if no improvement for 10 epochs
    save=True,
    plots=True           # automatically saves results.png, confusion matrix, etc.
)

print("\n✅ Training complete!")
print(f"Best model saved at: runs/detect/missile_det/weights/best.pt")
print(f"Performance plots saved in: runs/detect/missile_det/")
                

